{
  "buildCommand": "echo skip",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/api/airspace",
      "dest": "/api/airspace.js"
    },
    {
      "src": "/",
      "dest": "/examples/basic.html"
    },
    {
      "src": "/examples/(.*)",
      "dest": "/examples/$1"
    },
    {
      "src": "/dist/(.*)",
      "dest": "/dist/$1"
    }
  ]
}
